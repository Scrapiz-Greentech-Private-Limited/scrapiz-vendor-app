EXPO_PUBLIC_SENTRY_AUTH_TOKEN=sentry-auth-token-from-infisical
EXPO_PUBLIC_POSTHOG_API_KEY=posthog-api-key
EXPO_PUBLIC_POSTHOG_HOST=posthog-host

# Map Implementation Keys
EXPO_PUBLIC_MAPBOX_API_KEY=<MAPBOX_PUBLIC_TOKEN>
MAPBOX_DOWNLOADS_TOKEN=<MAPBOX_DOWNLOADS_TOKEN>
EXPO_PUBLIC_KRUTRIM_API_KEY=your_ola_maps_krutrim_api_key_here
EXPO_PUBLIC_GOOGLE_API_KEY=your_google_api_key_here
# Enable mock fallback pickup cards only for explicit local QA.
EXPO_PUBLIC_ENABLE_VENDOR_FALLBACK_BOOKINGS=false
# Legacy flag retained for older builds; keep disabled.
EXPO_PUBLIC_VENDOR_FALLBACK_TESTING=false